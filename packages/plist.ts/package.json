{
  "name": "@sapkalabs/plist.ts",
  "version": "0.2.0",
  "description": "TypeScript-first Apple property list parser, serializer, and validator for modern ESM Node.js projects",
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "clean": "node -e \"require('node:fs').rmSync('lib', { recursive: true, force: true })\"",
    "prepack": "yarn clean && yarn build",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "plist",
    "plist-parser",
    "plist-builder",
    "plist-serializer",
    "property-list",
    "apple",
    "ios",
    "macos",
    "xcode",
    "info-plist",
    "entitlements",
    "mobileprovision",
    "provisioning-profile",
    "xml",
    "typescript",
    "esm",
    "nodejs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SapkaLabs/plist.ts.git",
    "directory": "packages/plist.ts"
  },
  "author": "SapkaLabs <info@sapkalabs.com> (https://github.com/SapkaLabs)",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "bugs": {
    "url": "https://github.com/SapkaLabs/plist.ts/issues"
  },
  "homepage": "https://github.com/SapkaLabs/plist.ts#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.6",
    "xmlbuilder": "^15.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  }
}
